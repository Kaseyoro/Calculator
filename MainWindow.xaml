<!-- Главное окно приложения -->
<!-- x:Class — связывает XAML с классом MainWindow в C# -->
<!-- KeyDown — обработчик нажатий клавиатуры, объявлен на уровне окна -->
<Window x:Class="Calculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Calculator"
        Height="580"
        Width="320"
        Background="#1c1c1e"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <!-- ═══════════════════════════════════════════════════════════════
             СТИЛИ — описывают внешний вид кнопок по группам.
             Определяются один раз здесь и применяются ко всем кнопкам.
        ════════════════════════════════════════════════════════════════ -->

        <!-- Базовый стиль — применяется ко ВСЕМ кнопкам автоматически -->
        <Style TargetType="Button">
            <Setter Property="Margin" Value="4"/>
            <!-- отступ между кнопками -->
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Height" Value="62"/>
            <Setter Property="Foreground" Value="#e5e5e7"/>
            <!-- цвет текста — светло-серый -->
            <Setter Property="Background" Value="#2c2c2e"/>
            <!-- фон кнопки — тёмно-серый -->
            <Setter Property="BorderThickness" Value="0"/>
            <!-- убираем рамку -->

            <!-- RenderTransform нужен для анимации нажатия (масштабирование) -->
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <!-- центр масштабирования -->
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform/>
                    <!-- трансформация масштаба, начальное значение 1.0 -->
                </Setter.Value>
            </Setter>

            <!-- Template полностью переопределяет внешний вид кнопки -->
            <!-- Стандартная кнопка WPF выглядит по-windows, нам нужны скруглённые углы -->
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <!-- Border — основа кнопки со скруглёнными углами -->
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12">
                            <!-- ContentPresenter отображает текст кнопки (Content) -->
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <!-- Триггеры меняют фон при наведении и нажатии -->
                        <ControlTemplate.Triggers>
                            <!-- Наведение мыши — чуть светлее -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3a3a3c"/>
                            </Trigger>
                            <!-- Нажатие — ещё светлее -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#48484a"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <!-- Анимация нажатия — кнопка "вдавливается" (уменьшается до 93%) -->
            <Style.Triggers>
                <Trigger Property="IsPressed" Value="True">
                    <!-- EnterActions — что происходит когда кнопка нажата -->
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <!-- Уменьшаем по X и Y до 0.93 за 70мс -->
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                 To="0.93" Duration="0:0:0.07"/>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                 To="0.93" Duration="0:0:0.07"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <!-- ExitActions — что происходит когда кнопку отпускают -->
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <!-- Возвращаем к нормальному размеру за 100мс -->
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                 To="1" Duration="0:0:0.1"/>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                 To="1" Duration="0:0:0.1"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для кнопок операторов (+, -, *, /, √, x²) -->
        <!-- BasedOn наследует всё из базового стиля, мы только меняем цвета -->
        <Style x:Key="OperatorButton" TargetType="Button"
               BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#2c2c2e"/>
            <Setter Property="Foreground" Value="#ff9f0a"/>
            <!-- оранжевый текст -->
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Стиль для служебных кнопок (C и ⌫) -->
        <!-- Чуть светлее фон, серый текст — визуально менее акцентные -->
        <Style x:Key="SpecialButton" TargetType="Button"
               BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#3a3a3c"/>
            <Setter Property="Foreground" Value="#98989d"/>
            <!-- серый текст -->
            <Setter Property="FontSize" Value="16"/>
        </Style>

    </Window.Resources>

    <!-- ═══════════════════════════════════════════════════════════════════
         РАЗМЕТКА — делим окно на две части: дисплей и кнопки
    ════════════════════════════════════════════════════════════════════ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="130"/>
            <!-- фиксированная высота для дисплея -->
            <RowDefinition Height="*"/>
            <!-- * — занимает всё оставшееся место -->
        </Grid.RowDefinitions>

        <!-- ДИСПЛЕЙ — верхняя часть, фон не задан (прозрачный = цвет окна) -->
        <Grid Grid.Row="0" Margin="16,16,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <!-- строка истории — занимает всё свободное -->
                <RowDefinition Height="56"/>
                <!-- строка результата — фиксированная высота -->
            </Grid.RowDefinitions>

            <!-- Строка истории: показывает предыдущее выражение ("5 + 3 =") -->
            <!-- TextTrimming обрезает текст с "..." если не помещается -->
            <TextBlock x:Name="HistoryLine"
                       Grid.Row="0"
                       FontSize="15"
                       Foreground="#48484a"        
                       TextAlignment="Right"
                       VerticalAlignment="Bottom"
                       Padding="0,0,4,4"
                       TextTrimming="CharacterEllipsis"/>

            <!-- Основной дисплей: показывает текущее выражение или результат -->
            <!-- IsReadOnly — пользователь не может печатать напрямую в поле -->
            <!-- Background Transparent — сливается с фоном окна, нет чёрного прямоугольника -->
            <TextBox x:Name="Display"
                     Grid.Row="1"
                     FontSize="42"
                     FontWeight="Light"
                     Background="Transparent"
                     Foreground="#f5f5f7"
                     BorderThickness="0"
                     TextAlignment="Right"
                     VerticalContentAlignment="Center"
                     IsReadOnly="True"
                     Padding="0"/>
        </Grid>

        <!-- Тонкая линия-разделитель между дисплеем и кнопками -->
        <Border Grid.Row="0"
                Height="1"
                Background="#2c2c2e"
                VerticalAlignment="Bottom"/>

        <!-- КНОПКИ — UniformGrid автоматически делает все ячейки одинакового размера -->
        <!-- Columns="4" — 4 колонки, кнопки добавляются слева направо, сверху вниз -->
        <UniformGrid Grid.Row="1" Columns="4" Margin="8,8,8,12">

            <!-- Ряд 1: служебные кнопки -->
            <Button Content="C"  Style="{StaticResource SpecialButton}"  Click="Clear_Click"/>
            <Button Content="⌫" Style="{StaticResource SpecialButton}"  Click="Backspace_Click"/>
            <Button Content="√"  Style="{StaticResource OperatorButton}" Click="Sqrt_Click"/>
            <Button Content="x²" Style="{StaticResource OperatorButton}" Click="Square_Click"/>
            <Button Content="4"  Click="Button_Click" Margin="4,10,4,11"/>

            <!-- Ряд 2: 7 8 9 / -->
            <Button Content="7"  Click="Button_Click"/>
            <Button Content="8"  Click="Button_Click"/>
            <Button Content="9"  Click="Button_Click"/>

            <!-- Ряд 3: 4 5 6 * -->
            <Button Content="5"  Click="Button_Click"/>
            <Button Content="6"  Click="Button_Click"/>
            <Button Content="*"  Style="{StaticResource OperatorButton}" Click="Button_Click"/>

            <!-- Ряд 4: 1 2 3 - -->
            <Button Content="1"  Click="Button_Click"/>
            <Button Content="2"  Click="Button_Click"/>
            <Button Content="3"  Click="Button_Click"/>
            <Button Content="-"  Style="{StaticResource OperatorButton}" Click="Button_Click"/>

            <!-- Ряд 5: 0 . = + -->
            <!-- Кнопка "=" — оранжевый фон задан напрямую, без отдельного стиля -->
            <Button Content="0"  Click="Button_Click"/>
            <Button Content="."  Click="Button_Click"/>
            <Button Content="="  Click="Equals_Click"
                    Background="#ff9f0a" Foreground="White"/>
            <Button Content="+"  Style="{StaticResource OperatorButton}" Click="Button_Click"/>
            <Button Content="/"  Style="{StaticResource OperatorButton}" Click="Button_Click" Margin="4,10,4,11"/>

        </UniformGrid>
    </Grid>
</Window>